# App
APP_NAME=ERP Test Case Generator
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# LLM provider: "gemini" | "openai" | "groq"
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.0-flash
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096

# Embeddings provider: "gemini" | "openai"
EMBEDDINGS_PROVIDER=gemini

# Google gemini
GEMINI_API_KEY=AIzaxxxxx
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBED_MODEL=text-embedding-004

# Pinecone
# Dimension must match the embeddings model:
#   gemini text-embedding-004 -> 768
#   openai text-embedding-3-small -> 1536
PINECONE_API_KEY=pc-xxxxx
PINECONE_INDEX=erp-testgen
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_DIMENSION=768

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j

# Chunking
CHUNK_SIZE=800
CHUNK_OVERLAP=120
TOP_K=6
